{
  "Claude": {
    "WorkingDirectory": "",
    "CliPath": "",
    "MaxTurns": 50,
    "BridgeTerminalTool": true,
    "ModelsCacheTtlMinutes": 30,
    "DefaultEffort": "high",
    "SupportedEfforts": [ "low", "medium", "high", "xhigh", "max" ],
    "McpToolTimeoutMs": 600000,
    "MaxMcpOutputTokens": 100000
  },
  "ModelDefaults": {
    "*": { "ContextLength": 200000, "Capabilities": [ "completion", "tools", "vision" ] },
    "opus": { "DisplayName": "Opus 4.8", "ContextLength": 1000000, "Capabilities": [ "completion", "tools", "vision" ] },
    "sonnet": { "DisplayName": "Sonnet 4.6", "ContextLength": 1000000, "Capabilities": [ "completion", "tools", "vision" ] },
    "haiku": { "DisplayName": "Haiku 4.5", "ContextLength": 200000, "Capabilities": [ "completion", "tools" ] },
    "fable": { "DisplayName": "Fable 5", "ContextLength": 1000000, "Capabilities": [ "completion", "tools", "vision" ] }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "File": {
      "BasePath": "Logs",
      "FileAccessMode": "KeepOpenAndAutoFlush",
      "FileEncodingName": "utf-8",
      "DateFormat": "yyyyMMdd",
      "CounterFormat": "000",
      "MaxFileSize": 10485760,
      "TextBuilderType": "ClaudeCodeOllamaProxy.Service.Logging.CustomLogFormatTextBuilder, ClaudeCodeOllamaProxy",
      "Files": [
        {
          "Path": "<appname>-<date>-<launch>-<counter>.log",
          "MinLevel": { "Default": "Trace" }
        }
      ]
    }
  },
  "AllowedHosts": "*"
}
