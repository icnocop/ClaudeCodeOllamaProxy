<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClaudeCodeOllamaProxy.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Port -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE968;" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Port" />
                            <TextBlock Text="The local port the proxy listens on. The default Ollama port is 11434. Changes take effect after a restart."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- ValidationMode=InvalidInputOverwritten makes the NumberBox enforce Minimum/Maximum:
                                 out-of-range numbers are clamped and empty/non-numeric input reverts to the last
                                 valid value, so the port can never be 0, negative, >65535, or empty. -->
                            <NumberBox x:Name="PortBox"
                                       Minimum="1" Maximum="65535"
                                       SpinButtonPlacementMode="Inline"
                                       ValidationMode="InvalidInputOverwritten"
                                       ValueChanged="PortBox_ValueChanged" MinWidth="160" />
                            <Button x:Name="PortDefaultButton" Content="Default"
                                    Click="PortDefaultButton_Click"
                                    ToolTipService.ToolTip="Set to the default Ollama port (11434)" />
                        </StackPanel>
                    </Grid>
                    <InfoBar x:Name="PortRestartBar" IsOpen="False" IsClosable="False"
                             Severity="Informational"
                             Message="The proxy is still using the previous port. Restart to apply the change.">
                        <InfoBar.ActionButton>
                            <Button Content="Restart now" Click="RestartProxyButton_Click" />
                        </InfoBar.ActionButton>
                    </InfoBar>
                </StackPanel>
            </Border>

            <!-- Run at startup -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE7E8;" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Run at startup" />
                        <TextBlock Text="Start Claude Code Ollama Proxy automatically when you sign in."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="StartupToggle" Grid.Column="2"
                                  Toggled="StartupToggle_Toggled" />
                </Grid>
            </Border>

            <!-- Minimize to tray on close -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE7B3;" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Minimize to system tray on close" />
                        <TextBlock Text="When on, closing the window hides it and the proxy keeps running in the tray. When off, closing quits the app."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="MinimizeToTrayToggle" Grid.Column="2"
                                  Toggled="MinimizeToTrayToggle_Toggled" />
                </Grid>
            </Border>

            <!-- Run as administrator -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7EF;" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Run as administrator" />
                            <TextBlock Text="Always start elevated. The Claude CLI the proxy launches also runs as administrator."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AdminToggle" Grid.Column="2"
                                      Toggled="AdminToggle_Toggled" />
                    </Grid>
                    <Button x:Name="RestartAdminButton" Click="RestartAdminButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7EF;" FontSize="14" />
                            <TextBlock Text="Restart as administrator" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="AdminStatusText" Text="The app is currently running as administrator."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- App theme -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE771;" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="App theme" />
                        <TextBlock Text="Choose how the app and tray icon follow light or dark mode."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeCombo" Grid.Column="2" VerticalAlignment="Center"
                              SelectionChanged="ThemeCombo_SelectionChanged" MinWidth="160">
                        <ComboBoxItem Content="System default" Tag="System" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Window size -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE73F;" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Window size and position" />
                        <TextBlock Text="Reset the main window to its default size and re-center it on screen. The navigation pane stays as it is."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button x:Name="ResetWindowSizeButton" Grid.Column="2" VerticalAlignment="Center"
                            Content="Reset size and center" Click="ResetWindowSizeButton_Click" />
                </Grid>
            </Border>

            <!-- Reset -->
            <Button x:Name="ResetButton" Click="ResetButton_Click" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                    <TextBlock Text="Reset to default settings" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>
