<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClaudeCodeOllamaProxy.UI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Home" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Status card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="Gray" />
                        <TextBlock x:Name="StatusText" Text="Stopped"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Listening URL" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="UrlBox" IsReadOnly="True" MinWidth="280" VerticalAlignment="Center" />
                        <Button x:Name="CopyButton" Click="CopyButton_Click" ToolTipService.ToolTip="Copy URL">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock Text="Copy" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Controls -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="StartButton" Click="StartButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="14" />
                        <TextBlock Text="Start" />
                    </StackPanel>
                </Button>
                <Button x:Name="StopButton" Click="StopButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71A;" FontSize="14" />
                        <TextBlock Text="Stop" />
                    </StackPanel>
                </Button>
                <Button x:Name="RestartButton" Click="RestartButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="Restart" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Set this URL as the Ollama endpoint in Visual Studio / VS Code Copilot Chat's BYOK Ollama provider." />

            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="The port can be changed in" />
                <HyperlinkButton Content="Settings" Click="SettingsLink_Click" Padding="4,0" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
