<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ClaudeCodeOllamaProxy.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <muxc:NavigationView
            x:Name="Nav"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="False"
            OpenPaneLength="150"
            PaneDisplayMode="Left"
            SelectionChanged="Nav_SelectionChanged"
            Loaded="Nav_Loaded">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Home" Tag="home" AutomationProperties.AutomationId="NavHome">
                    <muxc:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Logs" Tag="logs" AutomationProperties.AutomationId="NavLogs">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem x:Name="SettingsNavItem" Content="Settings" Tag="settings" AutomationProperties.AutomationId="NavSettings">
                    <muxc:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="About" Tag="about" AutomationProperties.AutomationId="NavAbout">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
